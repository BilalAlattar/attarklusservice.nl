{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/admin.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/contact.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/admin", "dest": "/api/admin.ts" },
    { "src": "/api/contact", "dest": "/api/contact.ts" },
    { "src": "/(.*)", "dest": "/api/index.ts" }
  ]
}
