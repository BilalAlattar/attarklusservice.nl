{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@now/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/index.ts",
      "use": "@now/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(.*)", "dest": "/api/index.ts" }
  ]
}
